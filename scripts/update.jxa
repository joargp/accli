// update.jxa - Update an existing event (EventKit)
// __args is injected by jxa-runner.js
// Expected args: { calendarName, calendarId, calendarIndex, eventId, summary, start, end, location, description, allDay, noAllDay }

(function() {
  ObjC.import('Foundation');
  ObjC.import('EventKit');

  var args = __args;

  function unwrap(x) {
    return ObjC.unwrap(x);
  }

  function toNSDate(date) {
    return $.NSDate.dateWithTimeIntervalSince1970(date.getTime() / 1000);
  }

  function ensureCalendarAccess(store) {
    var status = $.EKEventStore.authorizationStatusForEntityType($.EKEntityTypeEvent);

    var fullAccessStatus =
      typeof $.EKAuthorizationStatusFullAccess !== 'undefined' ? $.EKAuthorizationStatusFullAccess : null;
    var writeOnlyStatus =
      typeof $.EKAuthorizationStatusWriteOnly !== 'undefined' ? $.EKAuthorizationStatusWriteOnly : null;

    if (status === $.EKAuthorizationStatusAuthorized || (fullAccessStatus !== null && status === fullAccessStatus)) {
      return { ok: true };
    }

    // "Add Only Access" / write-only is not sufficient for listing calendars/events.
    if (writeOnlyStatus !== null && status === writeOnlyStatus) {
      return {
        ok: false,
        error: {
          code: 'NOT_AUTHORIZED',
          message:
            'Calendar access is set to Add Only (write-only). Change it to Full Access in System Settings > Privacy & Security > Calendars (Options… button).'
        }
      };
    }

    if (status === $.EKAuthorizationStatusNotDetermined) {
      var done = false;
      var granted = false;

      if (store.respondsToSelector($.NSSelectorFromString($('requestFullAccessToEventsWithCompletion:')))) {
        store.requestFullAccessToEventsWithCompletion(function(g, err) {
          granted = !!g;
          done = true;
        });
      } else {
        store.requestAccessToEntityTypeCompletion($.EKEntityTypeEvent, function(g, err) {
          granted = !!g;
          done = true;
        });
      }

      var start = $.NSDate.date;
      while (!done) {
        var elapsed = $.NSDate.date.timeIntervalSinceDate(start);
        if (elapsed > 15.0) {
          done = true;
          granted = false;
          break;
        }
        $.NSRunLoop.currentRunLoop.runUntilDate($.NSDate.dateWithTimeIntervalSinceNow(0.05));
      }

      if (granted) {
        return { ok: true };
      }
    }

    return {
      ok: false,
      error: {
        code: 'NOT_AUTHORIZED',
        message:
          'Calendar access not granted. Enable Full Access (not Add Only) in System Settings > Privacy & Security > Calendars (Options… button) for the responsible app (often \"osascript\" and/or your terminal).'
      }
    };
  }

  function formatLocalDate(date) {
    var year = date.getFullYear();
    var month = String(date.getMonth() + 1).padStart(2, '0');
    var day = String(date.getDate()).padStart(2, '0');
    var hours = String(date.getHours()).padStart(2, '0');
    var minutes = String(date.getMinutes()).padStart(2, '0');
    var seconds = String(date.getSeconds()).padStart(2, '0');
    return year + '-' + month + '-' + day + 'T' + hours + ':' + minutes + ':' + seconds;
  }

  function formatDateOnly(date) {
    var year = date.getFullYear();
    var month = String(date.getMonth() + 1).padStart(2, '0');
    var day = String(date.getDate()).padStart(2, '0');
    return year + '-' + month + '-' + day;
  }

  function displayEndDateForAllDay(startDate, endDate) {
    var adjusted = new Date(endDate.getTime());
    adjusted.setDate(adjusted.getDate() - 1);
    return formatDateOnly(adjusted) < formatDateOnly(startDate) ? startDate : adjusted;
  }

  function parseDateTime(str) {
    if (!str) return null;
    if (/^\d{4}-\d{2}-\d{2}$/.test(str)) {
      return new Date(str + 'T00:00:00');
    }
    return new Date(str);
  }

  function startOfDay(date) {
    return new Date(date.getFullYear(), date.getMonth(), date.getDate(), 0, 0, 0);
  }

  function parseAllDayDate(str, isEnd) {
    var d = parseDateTime(str);
    var base = startOfDay(d);
    if (isEnd) {
      base.setDate(base.getDate() + 1);
    }
    return base;
  }

  function listCalendars(store) {
    var calendars = store.calendarsForEntityType($.EKEntityTypeEvent);
    var items = [];

    for (var i = 0; i < calendars.count; i++) {
      var cal = calendars.objectAtIndex(i);
      items.push({
        cal: cal,
        id: unwrap(cal.calendarIdentifier),
        name: unwrap(cal.title),
        source: unwrap(cal.source.title)
      });
    }

    items.sort(function(a, b) {
      var sa = (a.source || '') + '\n' + (a.name || '') + '\n' + (a.id || '');
      var sb = (b.source || '') + '\n' + (b.name || '') + '\n' + (b.id || '');
      return sa.localeCompare(sb);
    });

    for (var j = 0; j < items.length; j++) {
      items[j].index = String(j);
    }

    return items;
  }

  function findCalendar(store, name, id, index) {
    var calendars = listCalendars(store);

    if (id !== null && id !== undefined) {
      for (var i = 0; i < calendars.length; i++) {
        if (calendars[i].id === id) {
          return { calendar: calendars[i], error: null };
        }
      }
      return {
        calendar: null,
        error: { code: 'CALENDAR_NOT_FOUND', message: 'Calendar with ID \"' + id + '\" not found' }
      };
    }

    if (index !== null && index !== undefined) {
      var idx = parseInt(index, 10);
      if (isNaN(idx) || idx < 0 || idx >= calendars.length) {
        return {
          calendar: null,
          error: { code: 'CALENDAR_NOT_FOUND', message: 'Calendar with index \"' + index + '\" not found' }
        };
      }
      return { calendar: calendars[idx], error: null };
    }

    var matches = [];
    for (var j = 0; j < calendars.length; j++) {
      if (calendars[j].name === name) {
        matches.push(calendars[j]);
      }
    }

    if (matches.length === 0) {
      return {
        calendar: null,
        error: { code: 'CALENDAR_NOT_FOUND', message: 'Calendar \"' + name + '\" not found' }
      };
    }

    if (matches.length > 1) {
      var ids = [];
      for (var k = 0; k < matches.length; k++) {
        ids.push(matches[k].id);
      }
      return {
        calendar: null,
        error: {
          code: 'AMBIGUOUS_CALENDAR',
          message: 'Multiple calendars named \"' + name + '\". Use --calendar-id with one of: ' + ids.join(', ')
        }
      };
    }

    return { calendar: matches[0], error: null };
  }

  var store = $.EKEventStore.alloc.init;
  var access = ensureCalendarAccess(store);
  if (!access.ok) {
    return JSON.stringify({ ok: false, error: access.error });
  }

  var calResult = findCalendar(store, args.calendarName, args.calendarId, args.calendarIndex);
  if (calResult.error) {
    return JSON.stringify({ ok: false, error: calResult.error });
  }

  var calendarInfo = calResult.calendar;
  var event = store.eventWithIdentifier(args.eventId);

  if (!event) {
    return JSON.stringify({
      ok: false,
      error: { code: 'EVENT_NOT_FOUND', message: 'Event with ID \"' + args.eventId + '\" not found' }
    });
  }

  if (unwrap(event.calendar.calendarIdentifier) !== calendarInfo.id) {
    return JSON.stringify({
      ok: false,
      error: { code: 'EVENT_NOT_FOUND', message: 'Event with ID \"' + args.eventId + '\" not found' }
    });
  }

  try {
    var currentAllDay = !!unwrap(event.allDay);
    var currentStart = unwrap(event.startDate);
    var currentEnd = unwrap(event.endDate);
    var warning = null;

    var isRecurring = false;
    try {
      isRecurring = event.recurrenceRules && event.recurrenceRules.count > 0;
    } catch (e) {
      // ignore
    }

    if (isRecurring) {
      warning = 'This is a recurring event; only this occurrence was updated';
    }

    var targetAllDay = currentAllDay;
    if (args.allDay) {
      targetAllDay = true;
    } else if (args.noAllDay) {
      targetAllDay = false;
    }

    var newStart = null;
    var newEnd = null;

    if (args.start) {
      newStart = targetAllDay ? parseAllDayDate(args.start, false) : parseDateTime(args.start);
    }

    if (args.end) {
      newEnd = targetAllDay ? parseAllDayDate(args.end, true) : parseDateTime(args.end);
    }

    // Reasonable conversions when toggling all-day without explicit dates
    if ((args.allDay || args.noAllDay) && !args.start && !args.end) {
      if (targetAllDay) {
        var d = startOfDay(currentStart);
        newStart = d;
        newEnd = new Date(d.getTime());
        newEnd.setDate(newEnd.getDate() + 1);
      } else {
        var startTimed = new Date(currentStart.getTime());
        startTimed.setHours(9, 0, 0, 0);
        var endTimed = new Date(startTimed.getTime());
        endTimed.setHours(10, 0, 0, 0);
        newStart = startTimed;
        newEnd = endTimed;
      }
    }

    var effectiveStart = newStart || currentStart;
    var effectiveEnd = newEnd || currentEnd;

    if (targetAllDay) {
      if (effectiveStart >= effectiveEnd) {
        return JSON.stringify({
          ok: false,
          error: { code: 'INVALID_RANGE', message: 'Start date must be on or before end date' }
        });
      }
    } else {
      if (effectiveStart >= effectiveEnd) {
        return JSON.stringify({
          ok: false,
          error: { code: 'INVALID_RANGE', message: 'Start must be before end' }
        });
      }
    }

    if (args.summary !== null && args.summary !== undefined) {
      event.title = args.summary;
    }

    if (args.location !== null && args.location !== undefined) {
      event.location = args.location;
    }

    if (args.description !== null && args.description !== undefined) {
      event.notes = args.description;
    }

    if (args.allDay || args.noAllDay) {
      event.allDay = targetAllDay;
    }

    if (newStart) {
      event.startDate = toNSDate(newStart);
    }

    if (newEnd) {
      event.endDate = toNSDate(newEnd);
    }

    var err = Ref();
    var saved = store.saveEventSpanError(event, $.EKSpanThisEvent, err);
    if (!saved) {
      var e = err[0];
      var msg = e ? unwrap(e.localizedDescription) : 'Unknown error';
      return JSON.stringify({
        ok: false,
        error: { code: 'JXA_ERROR', message: 'Failed to update event: ' + msg }
      });
    }

    var updatedStart = unwrap(event.startDate);
    var updatedEnd = unwrap(event.endDate);
    var updatedAllDay = !!unwrap(event.allDay);
    var displayEnd = updatedEnd;
    if (updatedAllDay) {
      displayEnd = displayEndDateForAllDay(updatedStart, updatedEnd);
    }

    return JSON.stringify({
      ok: true,
      event: {
        id: unwrap(event.eventIdentifier),
        calendar: calendarInfo.name,
        calendarId: calendarInfo.id,
        summary: unwrap(event.title) || '',
        allDay: updatedAllDay,
        start: updatedAllDay ? formatDateOnly(updatedStart) : formatLocalDate(updatedStart),
        end: updatedAllDay ? formatDateOnly(displayEnd) : formatLocalDate(displayEnd)
      },
      warning: warning
    });
  } catch (e) {
    return JSON.stringify({
      ok: false,
      error: { code: 'JXA_ERROR', message: 'Failed to update event: ' + e.message }
    });
  }
})();
